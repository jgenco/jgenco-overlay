		! use llvm && ( sed -i 's/"-g1"/"-g0"/' \
			"$(find_crate ^v8- p)/build/config/compiler/BUILD.gn" || die )
		#https://github.com/denoland/deno_third_party/tree/master/prebuilt/linux64
