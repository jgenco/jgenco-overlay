		ln -s "${esbuild_bin[-1]}" third_party/prebuilt/linux64/esbuild-x64 || die
	fi
	#disables test that need network
	awk -i inplace \
		'BEGIN {p = 0}
		/(dns|test-http-https-default-ports).*{/ {p=1}
		{ if(p) print "//"$0"// need internet";else print $0 }
		/},/ {p=0}' \
		tests/node_compat/config.jsonc || die
	#sockets work in terminal; sytle does not, quiet error for now
	sed -Ei  "/test-fs-cp-(sync-copy|async)-socket/d;/test-util-styletext.js/d" \
		tests/node_compat/config.jsonc || die
	#panics but not when run on terminal :|
	rm tests/napi/worker_termination_* || die

	local spec_dir="tests/specs"
	local spec_tests=(
		${spec_dir}/cert/deno_land_unsafe_ssl #net
		${spec_dir}/cert/ip_address_unsafe_ssl #net
