		${spec_dir}/upgrade #upgrade/net
		${spec_dir}/run/sslkeylogfile #net
		tests/unit_node/dns_test.ts # net
	)
	rm -r ${spec_tests[@]} || die
	find ${spec_dir} -type d -empty -print -delete || die

	sed "s#/usr/bin/sh#${EPREFIX}/bin/sh#" -i tests/unit/serve_test.ts || die
