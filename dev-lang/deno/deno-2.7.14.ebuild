function find_crate() {
	[[ ${#} -eq 0 ]] && die "No crate name provided"
	cd ${ECARGO_VENDOR}
	for crate in *;do
		if [[ ${crate} =~ ${1} ]];then
			[[ ${2} == "p" ]] && echo -n "${ECARGO_VENDOR}/"
			echo "${crate}" && return
		fi
	done
	die "Crate $1 not found"
}

disk_space_check() {
	local disk_space="13"
	local disk_space_test="7"
	if ! use v8-prebuilt; then
		disk_space="$(usex llvm 15 19)"
		disk_space_test="$(usex llvm 7 2)"
	fi
	use test && disk_space=$((${disk_space} + ${disk_space_test}))
	local CHECKREQS_DISK_BUILD="${disk_space}G"
	check-reqs_${EBUILD_PHASE_FUNC}
}
pkg_pretend() {
	disk_space_check
}

